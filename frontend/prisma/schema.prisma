generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  displayName   String?
  role          String         @default("guest")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  emailVerified DateTime?
  image         String?
  name          String?
  /// 이메일/비밀번호 가입용 (OAuth 전용 계정은 null)
  passwordHash  String?
  phoneNumber   String?
  preferredLanguage String?
  gender        String?
  isOwner       Boolean        @default(false)
  blocked       Boolean        @default(false)
  blockedAt     DateTime?
  blockedReason String?
  deleted       Boolean        @default(false)
  deletedAt     DateTime?
  /// none | pending | verified | rejected (앱·관리자 목록용)
  verificationStatus String    @default("none")
  /// private_data, kyc_steps 등 앱 전용 확장 JSON
  profileJson   Json?
  accounts      Account[]
  bookings      Booking[]
  lessorProfile LessorProfile?
  properties    Property[]
  sessions      Session[]
  paymentRecords PaymentRecord[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Property {
  id                     String    @id @default(uuid())
  title                  String
  original_description   String?
  translated_description String?
  price                  Float
  priceUnit              String    @default("vnd")
  area                   Float
  bedrooms               Int?      @default(0)
  bathrooms              Int?      @default(0)
  lat                    Float?
  lng                    Float?
  address                String
  unitNumber             String?
  images                 String[]
  amenities              String[]
  maxAdults              Int?      @default(2)
  maxChildren            Int?      @default(0)
  status                 String    @default("active")
  ownerId                String
  checkInDate            DateTime?
  checkOutDate           DateTime?
  checkInTime            String?
  checkOutTime           String?
  hidden                 Boolean   @default(false)
  deleted                Boolean   @default(false)
  deletedAt              DateTime?
  /// history, iCal, pet, city/district 등 PropertyData 확장
  extraJson              Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  bookings               Booking[]
  owner                  User      @relation(fields: [ownerId], references: [id])
}

model Booking {
  id           String   @id @default(uuid())
  propertyId   String
  guestId      String
  checkInDate  DateTime
  checkOutDate DateTime
  totalPrice   Float
  status       String   @default("pending")
  /// 앱 BookingData 전량(JSON) — 컬럼과 병합해 사용
  detailJson   Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  guest        User     @relation(fields: [guestId], references: [id])
  property     Property @relation(fields: [propertyId], references: [id])
  paymentRecords PaymentRecord[]
}

model ChatRoom {
  id        String    @id @default(uuid())
  bookingId String?   @unique
  createdAt DateTime  @default(now())
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  roomId    String
  senderId  String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id])
}

model PaymentRecord {
  id                String   @id @default(cuid())
  bookingId         String
  userId            String
  amount            Float
  currency          String   @default("vnd")
  status            String   @default("pending")
  provider          String?
  externalPaymentId String?
  idempotencyKey    String?
  webhookEventId    String?
  refundStatus      String?
  refundAmount      Float?
  metaJson          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([userId, createdAt])
  @@index([status, updatedAt])
  @@unique([externalPaymentId])
  @@unique([idempotencyKey])
  @@unique([webhookEventId])
}

model LessorProfile {
  id                  String    @id @default(uuid())
  userId              String    @unique
  phoneNumber         String?
  phoneVerified       Boolean   @default(false)
  phoneVerifiedAt     DateTime?
  idType              String?
  idNumber            String?
  fullName            String?
  dateOfBirth         DateTime?
  issueDate           DateTime?
  expiryDate          DateTime?
  idDocumentFrontPath String?
  idDocumentBackPath  String?
  passportImagePath   String?
  faceFrontPath       String?
  faceUpPath          String?
  faceDownPath        String?
  faceLeftPath        String?
  faceRightPath       String?
  verificationStatus  String    @default("pending")
  kycStep1Completed   Boolean   @default(false)
  kycStep2Completed   Boolean   @default(false)
  kycStep3Completed   Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// * 백오피스 전용 관리자 계정
model AdminAccount {
  id           String   @id @default(cuid())
  username     String   @unique
  /// 표시용 닉네임(슈퍼만 생성·수정)
  nickname     String   @default("")
  passwordHash String
  isSuperAdmin Boolean  @default(false)
  permissions  Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// 관리자 간 공유 메모 (대상별)
model AdminSharedMemo {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  category   String
  content    String
  createdBy  String
  createdAt  DateTime @default(now())

  @@index([targetType, targetId, category, createdAt])
}

model AdminModerationAudit {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String
  ownerId    String?
  reason     String?
  createdBy  String
  createdAt  DateTime @default(now())

  @@index([createdAt, action])
  @@index([targetType, targetId, createdAt])
}

model AdminAckState {
  id            String   @id @default(cuid())
  adminUsername String
  category      String
  targetId      String
  acknowledgedAt DateTime @default(now())

  @@unique([adminUsername, category, targetId])
  @@index([adminUsername, category, acknowledgedAt])
}

model AdminSystemLog {
  id          String   @id @default(cuid())
  ts          DateTime @default(now())
  severity    String
  message     String
  category    String?
  bookingId   String?
  ownerId     String?
  snapshotJson Json?
  createdBy   String?

  @@index([ts, severity])
  @@index([category, ts])
}
