{
  "name": "500stayviet-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npm run prisma:generate && next build",
    "postinstall": "npm run prisma:generate",
    "lint": "eslint . --max-warnings 0",
    "lint:api-app": "eslint \"src/app/api/app/**/*.ts\" --max-warnings 0",
    "lint:api": "eslint \"src/app/api/**/*.ts\" --max-warnings 0",
    "lint:server": "eslint \"src/lib/server/**/*.ts\" --max-warnings 0",
    "lint:p3-tier2": "npm run lint:api && npm run lint:server",
    "lint:p3-lib": "eslint \"src/lib/**/*.ts\" --ignore-pattern \"src/lib/server/**\" --max-warnings 0",
    "lint:p3-components": "eslint \"src/components/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:p3-tier3": "npm run lint:p3-tier2 && npm run lint:p3-lib && npm run lint:p3-components",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "db:baseline": "node scripts/prisma-baseline.cjs",
    "qa:edge": "node scripts/edge-api-check.mjs",
    "check:banned-terms": "node scripts/check-banned-terms.mjs",
    "scan:ui-ko": "node scripts/scan-ui-korean-literals.mjs",
    "scan:ui-ko:gate": "node scripts/scan-ui-korean-literals.mjs --max-hits 125",
    "p3:i18n": "npm run scan:ui-ko:gate && vitest run src/utils/mergedUiTextKeysParity.test.ts src/utils/scanUiKoPolicy.test.ts",
    "test": "vitest run",
    "ci:parity": "npm run lint:p3-tier3 && npm run p3:i18n && npm test && npm run check:banned-terms && npx tsc --noEmit && npm run build",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "mobile:ios-sync": "npx cap sync ios",
    "mobile:ios-open": "npx cap open ios"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.975.0",
    "@aws-sdk/client-sns": "^3.975.0",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^10.48.0",
    "@tailwindcss/postcss": "^4.1.18",
    "autoprefixer": "^10.4.23",
    "axios": "^1.13.2",
    "firebase": "^11.0.2",
    "framer-motion": "^12.29.0",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^5.16.0",
    "next": "15.1.0",
    "next-auth": "^4.24.13",
    "next-pwa": "^5.6.0",
    "postcss": "^8.5.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.1.0",
    "prisma": "^6.19.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "preact": "10.24.3",
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0"
  }
}
